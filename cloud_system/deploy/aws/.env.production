# ============================================================================
# Production Environment Configuration
# Copy to .env and fill in your values
# ============================================================================

# ── App ──
APP_NAME=Dyslexia Detection Cloud System
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_STRING

# ── Paths (Docker-mapped) ──
MODEL_DIR=/app/saved_models
LOG_DIR=/app/logs
UPLOAD_DIR=/app/uploads

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["*"]

# ── OpenAI (optional — only for agentic training mode) ──
OPENAI_API_KEY=

# ── GPU (set false on CPU-only servers like t3.micro) ──
TF_FORCE_GPU_ALLOW_GROWTH=true
